# =============================================================================
# EstateFlow CRM - Environment Variables
# Copy this file to .env.local and fill in real values for local development.
# Do NOT commit .env.local. In Vercel, add these via Project Settings > Env Vars.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ---
# From Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...public-anon-key
SUPABASE_SERVICE_ROLE_KEY=ey...service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- Service mode ---
# "production" or "dry-run". In dry-run, Twilio/SMS/email are simulated.
SERVICE_MODE=dry-run

# --- Twilio Voice / SMS / WhatsApp ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="EstateFlow CRM <noreply@estateflow.app>"

# --- Lead webhook security ---
# Senders must include header `x-webhook-secret: <this value>`.
LEAD_WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- AI (OpenAI-compatible) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Default lead assignment ---
# round-robin | manual | least-busy
LEAD_ASSIGNMENT_MODE=round-robin
